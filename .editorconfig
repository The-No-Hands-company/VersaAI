# EditorConfig helps maintain consistent coding styles for multiple developers
# working on the same project across various editors and IDEs
# editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{cpp,h,hpp,c,cc,cxx}]
indent_style = space
indent_size = 2

[*.{py,pyi}]
indent_style = space
indent_size = 4

[*.{js,jsx,ts,tsx,json,html,css,scss,less,vue}]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false

[{Makefile,makefile,*.mk}]
indent_style = tab
indent_size = 4

[{CMakeLists.txt,*.cmake}]
indent_style = space
indent_size = 2

[*.{bat,cmd}]
end_of_line = crlf

[*.{ps1,psm1,psd1}]
end_of_line = crlf
